#!/bin/bash
# Bootstrap for tenant "{{ tenant.name }}" — runs as the unprivileged "app" user
# inside the container. Sets up rootless Docker on the ZFS-backed /data volume
# and lays down a cloudflared config skeleton (tunnel still needs `cloudflared
# tunnel login` + `tunnel create` run interactively — that step is not
# automatable without your Cloudflare credentials).
set -euo pipefail

changed=0
needs_restart=0

mark_changed() {
  changed=1
}

export XDG_RUNTIME_DIR="/run/user/$(id -u)"
export DBUS_SESSION_BUS_ADDRESS="unix:path=${XDG_RUNTIME_DIR}/bus"

if ! command -v dockerd >/dev/null 2>&1; then
  echo "dockerd not found — is docker.io installed?" >&2
  exit 1
fi

if ! command -v rootlesskit >/dev/null 2>&1; then
  echo "rootlesskit not found — is the rootlesskit package installed?" >&2
  exit 1
fi

if ! systemctl --user show-environment >/dev/null 2>&1; then
  echo "systemd user bus is not available for app; check loginctl linger" >&2
  exit 1
fi

mkdir -p "{{ tenant.data_root }}"
mkdir -p ~/.config/docker

desired_daemon_json="$(mktemp)"
cat > "${desired_daemon_json}" <<EOF
{ "data-root": "{{ tenant.data_root }}" }
EOF

if [ ! -f ~/.config/docker/daemon.json ] || \
  ! cmp -s "${desired_daemon_json}" ~/.config/docker/daemon.json; then
  mv "${desired_daemon_json}" ~/.config/docker/daemon.json
  needs_restart=1
  mark_changed
else
  rm -f "${desired_daemon_json}"
fi

if command -v dockerd-rootless-setuptool.sh >/dev/null 2>&1; then
  if [ ! -f ~/.config/systemd/user/docker.service ]; then
    dockerd-rootless-setuptool.sh install
    systemctl --user daemon-reload
    mark_changed
  fi
else
  desired_docker_service="$(mktemp)"
  cat > "${desired_docker_service}" <<'EOF'
[Unit]
Description=Docker Application Container Engine (Rootless)
Documentation=https://docs.docker.com/go/rootless/

[Service]
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/usr/bin/rootlesskit --net=slirp4netns --mtu=65520 --disable-host-loopback --copy-up=/etc --copy-up=/run /usr/bin/dockerd --rootless --host=unix://%t/docker.sock
ExecReload=/bin/kill -s HUP $MAINPID
TimeoutSec=0
RestartSec=2
Restart=always
StartLimitBurst=3
StartLimitInterval=60s
LimitNOFILE=infinity
LimitNPROC=infinity
LimitCORE=infinity
TasksMax=infinity
Delegate=yes
Type=notify
NotifyAccess=all
KillMode=mixed

[Install]
WantedBy=default.target
EOF

  if [ ! -f ~/.config/systemd/user/docker.service ] || \
    ! cmp -s "${desired_docker_service}" ~/.config/systemd/user/docker.service; then
    mkdir -p ~/.config/systemd/user
    mv "${desired_docker_service}" ~/.config/systemd/user/docker.service
    systemctl --user daemon-reload
    needs_restart=1
    mark_changed
  else
    rm -f "${desired_docker_service}"
  fi
fi

if ! systemctl --user is-enabled docker >/dev/null 2>&1; then
  systemctl --user enable docker
  mark_changed
fi

if ! systemctl --user is-active docker >/dev/null 2>&1; then
  systemctl --user start docker
  mark_changed
elif [ "${needs_restart}" -eq 1 ]; then
  systemctl --user restart docker
fi

grep -qxF 'export DOCKER_HOST=unix:///run/user/$(id -u)/docker.sock' ~/.bashrc || \
  {
    echo 'export DOCKER_HOST=unix:///run/user/$(id -u)/docker.sock' >> ~/.bashrc
    mark_changed
  }

mkdir -p ~/.cloudflared
if [ ! -f ~/.cloudflared/config.yml ]; then
  cat > ~/.cloudflared/config.yml <<'EOF'
# Fill in after `cloudflared tunnel login` and `cloudflared tunnel create {{ tenant.name }}`
# tunnel: {{ tenant.name }}
# credentials-file: /home/app/.cloudflared/<tunnel-id>.json
#
# ingress:
#   - hostname: ssh-{{ tenant.name }}.dominio.tld
#     service: ssh://localhost:22
#   - hostname: app-{{ tenant.name }}.dominio.tld
#     service: http://localhost:8080
#   - service: http_status:404
EOF
  mark_changed
fi

echo "bootstrap for {{ tenant.name }} complete"
echo "changed=${changed}"
